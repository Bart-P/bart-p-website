---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/site/NavBar.astro";
import Hero from "../components/home/Hero.astro";
import Problem from "../components/home/Problem.astro";
import Solution from "../components/home/Solution.astro";
import Offer from "../components/home/Offer.astro";
import Proof from "../components/home/Proof.astro";
import Faq from "../components/home/Faq.astro";
import Cta from "../components/home/Cta.astro";
import Footer from "../components/site/Footer.astro";
import { homeContent } from "../i18n/home";
import { commonContent } from "../i18n/common";

const lang = "en" as const;
const content = homeContent[lang];
const common = commonContent[lang];
---

<BaseLayout
    title="Astro Landing Page Starter"
    description="A clean Astro and Tailwind starter for a static landing page."
>
    <NavBar content={common.nav} />
    <div class="mx-auto max-w-6xl space-y-18 p-6">
        <Hero content={content.hero} />
        <Problem content={content.problem} />
        <Solution content={content.solution} />
        <Offer content={content.offers} />
        <Proof content={content.proof} />
        <Faq content={content.faq} />
        <Cta content={content.cta} />
    </div>
    <Footer content={common.footer} />
</BaseLayout>
