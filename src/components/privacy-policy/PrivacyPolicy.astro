---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { type Lang } from "../../types";

interface Props {
    lang: Lang;
    title: string;
}

const { lang, title } = Astro.props as Props;
---

<SiteLayout title={title} description="" lang={lang}>
    <section class="space-y-6">
        <h1 class="text-2xl font-bold">{title}</h1>
        {
            lang === "en" ? (
                <div
                    class="itrk-legaltext"
                    data-itrk-legaltext-url="https://itrk.legal/1zIp.99.18TZ-iframe.html"
                />
            ) : (
                <div
                    class="itrk-legaltext"
                    data-itrk-legaltext-url="https://itrk.legal/1zIp.8V.18TZ-informal-iframe.html"
                />
            )
        }
        <script
            is:inline
            src="https://www.it-recht-kanzlei.de/js/itrk-legaltext.js"></script>
    </section>
</SiteLayout>
