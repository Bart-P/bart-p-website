---
interface Props {
    variant?: "default" | "highlight";
    class?: string;
}

const { variant = "default", class: className } = Astro.props as Props;

const baseClass = "rounded-lg border p-6 shadow";
const variantClass =
    variant === "highlight" ? "border-primary/40 bg-primary-soft/30" : "border-border";
---

<div class:list={[baseClass, variantClass, className]}>
    <slot />
</div>
