---
interface Props {
    label?: string;
    title: string;
    intro?: string;
}

const { label, title, intro } = Astro.props as Props;
---

<div class="mb-6">
    {
        label && (
            <div class="text-primary mb-4 text-sm font-bold uppercase">
                {label}
            </div>
        )
    }
    <h2 class={intro ? "mb-4 text-2xl font-bold" : "text-2xl font-bold"}>
        {title}
    </h2>
    {intro && <p>{intro}</p>}
</div>
