---
import ButtonLink from "../ui/ButtonLink.astro";
import SectionHeader from "../ui/SectionHeader.astro";

interface Props {
    content: {
        sectionLabel: string;
        title: string;
        intro: string;
        projects: readonly {
            name: string;
            description: string;
        }[];
        sidebar: {
            title: string;
            body: string;
            primaryCta: string;
            secondaryCta: string;
        };
    };
    primaryCtaHref: string;
    secondaryCtaHref: string;
}

const { content, primaryCtaHref, secondaryCtaHref } = Astro.props as Props;
---

<div class="space-y-6">
    <SectionHeader
        label={content.sectionLabel}
        title={content.title}
        intro={content.intro}
    />
    <div class="flex flex-wrap gap-3 md:flex-nowrap">
        <div class="flex-2/3 space-y-3 md:p-3">
            {
                content.projects.map((project, index) => (
                    <div
                        class={
                            index === content.projects.length - 1
                                ? "space-y-2 pb-3"
                                : "border-border space-y-2 border-b pb-3"
                        }
                    >
                        <h3 class="font-semibold">{project.name}</h3>
                        <p>{project.description}</p>
                    </div>
                ))
            }
        </div>
        <div
            class="border-border flex-1/3 space-y-3 border-t md:border-t-0 md:border-l md:p-6"
        >
            <h4 class="font-bold">{content.sidebar.title}</h4>
            <p class="whitespace-pre-line">{content.sidebar.body}</p>

            <div class="space-y-3 space-x-3">
                <ButtonLink
                    href={primaryCtaHref}
                    variant="primary"
                    target="_blank"
                >
                    {content.sidebar.primaryCta}
                </ButtonLink>

                <ButtonLink href={secondaryCtaHref} variant="secondary">
                    {content.sidebar.secondaryCta}
                </ButtonLink>
            </div>
        </div>
    </div>
</div>
