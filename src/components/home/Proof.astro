---
interface Props {
    content: {
        sectionLabel: string;
        title: string;
        intro: string;
        projects: readonly {
            name: string;
            description: string;
        }[];
        sidebar: {
            title: string;
            body: string;
            primaryCta: string;
            secondaryCta: string;
        };
    };
}

const { content } = Astro.props as Props;
---

<div class="space-y-6">
    <div class="text-primary mb-5 text-sm font-bold uppercase">{content.sectionLabel}</div>
    <h2 class="mb-3 text-2xl font-bold">{content.title}</h2>
    <p>{content.intro}</p>
    <div class="flex gap-3">
        <div class="flex-2/3 space-y-3 p-3">
            {
                content.projects.map((project, index) => (
                    <div
                        class={index === content.projects.length - 1
                            ? "space-y-2 pb-3"
                            : "border-border space-y-2 border-b pb-3"}
                    >
                        <h3 class="font-semibold">{project.name}</h3>
                        <p>{project.description}</p>
                    </div>
                ))
            }
        </div>
        <div class="border-border flex-1/3 space-y-3 border-l p-6">
            <h4 class="font-bold">{content.sidebar.title}</h4>
            <p class="whitespace-pre-line">{content.sidebar.body}</p>

            <div class="space-x-3 space-y-3">
                <button
                    class="text-background bg-primary hover:bg-primary/80 hover:text-text/90 rounded-lg px-3 py-2 text-lg font-semibold transition"
                >
                    {content.sidebar.primaryCta}
                </button>

                <button
                    class="text-text bg-background border-border hover:bg-text/20 rounded-lg border px-3 py-2 text-lg transition"
                >
                    {content.sidebar.secondaryCta}
                </button>
            </div>
        </div>
    </div>
</div>
