---
import { Icon } from "astro-icon/components";

interface OfferCard {
    title: string;
    price: string;
    description: string;
    bestForTitle: string;
    bestFor: readonly string[];
    resultTitle: string;
    result: string;
}

interface Props {
    content: {
        sectionLabel: string;
        title: string;
        intro: string;
        cards: readonly OfferCard[];
        websiteOffer: OfferCard;
    };
}

const { content } = Astro.props as Props;
---

<div class="space-y-6">
    <div class="text-primary mb-5 text-sm font-bold uppercase">{content.sectionLabel}</div>
    <h2 class="mb-3 text-2xl font-bold">{content.title}</h2>
    <p>{content.intro}</p>
    <div class="grid grid-cols-3 gap-6">
        {
            content.cards.map((card, index) => (
                <div
                    class={index === 0
                        ? "border-primary/40 bg-primary-soft/30 flex flex-2/5 flex-col justify-between gap-3 rounded-lg border p-6 shadow"
                        : "border-border flex flex-2/5 flex-col justify-between rounded-lg border p-6 shadow"}
                >
                    <div class="space-y-3">
                        <h3 class="flex items-center gap-2 text-xl font-bold">
                            {card.title}
                        </h3>
                        <p class="text-primary font-bold">{card.price}</p>
                        <p>{card.description}</p>
                    </div>
                    <div class="space-y-3">
                        <h4 class="font-bold">{card.bestForTitle}</h4>
                        <ul>
                            {
                                card.bestFor.map((item) => (
                                    <li class="flex items-center gap-3">
                                        <Icon
                                            name="lucide:chevron-right"
                                            class="text-secondary"
                                        />
                                        {item}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                    <div class="space-y-3">
                        <h4 class="font-bold">{card.resultTitle}</h4>
                        <p>{card.result}</p>
                    </div>
                </div>
            ))
        }
    </div>
    <div class="border-border flex-2/5 space-y-3 rounded-lg border p-6 shadow">
        <h4
            class="border-border text-muted w-full border-b pb-6 text-center font-bold"
        >
            {content.websiteOffer.title}
        </h4>
        <div class="flex gap-3">
            <div class="flex-1/3 space-y-3">
                <p class="text-secondary font-bold">{content.websiteOffer.price}</p>
                <p>{content.websiteOffer.description}</p>
            </div>
            <div class="flex-1/3 space-y-3">
                <h4 class="text-muted font-bold">{content.websiteOffer.bestForTitle}</h4>
                <ul>
                    {
                        content.websiteOffer.bestFor.map((item) => (
                            <li class="flex items-center gap-3">
                                <Icon
                                    name="lucide:chevron-right"
                                    class="text-secondary"
                                />
                                {item}
                            </li>
                        ))
                    }
                </ul>
            </div>
            <div class="flex-1/3 space-y-3">
                <h4 class="text-muted font-bold">{content.websiteOffer.resultTitle}</h4>
                <p>{content.websiteOffer.result}</p>
            </div>
        </div>
    </div>
</div>
