---
import SectionHeader from "../ui/SectionHeader.astro";
import IconListItem from "../ui/IconListItem.astro";
import Card from "../ui/Card.astro";

interface OfferCard {
    title: string;
    price: string;
    description: string;
    bestForTitle: string;
    bestFor: readonly string[];
    resultTitle: string;
    result: string;
}

interface Props {
    content: {
        sectionLabel: string;
        title: string;
        intro: string;
        cards: readonly OfferCard[];
        websiteOffer: OfferCard;
    };
}

const { content } = Astro.props as Props;
---

<div class="space-y-6">
    <SectionHeader
        label={content.sectionLabel}
        title={content.title}
        intro={content.intro}
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
            content.cards.map((card, index) => (
                <Card
                    variant={index === 0 ? "highlight" : "default"}
                    class={index === 0
                        ? "flex flex-2/5 flex-col justify-between gap-3"
                        : "flex flex-2/5 flex-col justify-between"}
                >
                    <div class="space-y-3">
                        <h3 class="flex items-center gap-2 text-xl font-bold">
                            {card.title}
                        </h3>
                        <p class="text-primary font-bold">{card.price}</p>
                        <p>{card.description}</p>
                    </div>
                    <div class="space-y-3">
                        <h4 class="font-bold">{card.bestForTitle}</h4>
                        <ul>
                            {
                                card.bestFor.map((item) => (
                                    <IconListItem>{item}</IconListItem>
                                ))
                            }
                        </ul>
                    </div>
                    <div class="space-y-3">
                        <h4 class="font-bold">{card.resultTitle}</h4>
                        <p>{card.result}</p>
                    </div>
                </Card>
            ))
        }
    </div>
    <Card class="flex-2/5 space-y-3">
        <h4
            class="border-border text-muted w-full border-b pb-6 text-center font-bold"
        >
            {content.websiteOffer.title}
        </h4>
        <div class="flex gap-3">
            <div class="flex-1/3 space-y-3">
                <p class="text-secondary font-bold">{content.websiteOffer.price}</p>
                <p>{content.websiteOffer.description}</p>
            </div>
            <div class="flex-1/3 space-y-3">
                <h4 class="text-muted font-bold">{content.websiteOffer.bestForTitle}</h4>
                <ul>
                    {
                        content.websiteOffer.bestFor.map((item) => (
                            <IconListItem>{item}</IconListItem>
                        ))
                    }
                </ul>
            </div>
            <div class="flex-1/3 space-y-3">
                <h4 class="text-muted font-bold">{content.websiteOffer.resultTitle}</h4>
                <p>{content.websiteOffer.result}</p>
            </div>
        </div>
    </Card>
</div>
