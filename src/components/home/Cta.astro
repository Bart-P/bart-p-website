---
import ButtonLink from "../ui/ButtonLink.astro";

interface Props {
    content: {
        title: string;
        body: string;
        primaryCta: string;
    };
    primaryCtaHref: string;
}

const { content, primaryCtaHref } = Astro.props as Props;
---

<div
    class="bg-primary-soft/30 border-primary/30 space-y-6 rounded-lg border px-6 py-10 text-center"
>
    <h2 class="font-bold text-2xl">{content.title}</h2>
    <p>{content.body}</p>

    <ButtonLink href={primaryCtaHref} variant="primary" target="_blank">
        {content.primaryCta}
    </ButtonLink>
</div>
