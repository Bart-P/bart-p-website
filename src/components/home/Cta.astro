---
interface Props {
    content: {
        title: string;
        body: string;
        primaryCta: string;
    };
}

const { content } = Astro.props as Props;
---

<div
    class="bg-primary-soft/30 border-primary/30 space-y-6 rounded-lg border px-6 py-10 text-center"
>
    <h2 class="font-bold text-2xl">{content.title}</h2>
    <p>{content.body}</p>

    <button
        class="text-background bg-primary hover:bg-primary/80 hover:text-text/90 rounded-lg px-3 py-2 text-lg font-semibold transition"
    >
        {content.primaryCta}
    </button>
</div>
