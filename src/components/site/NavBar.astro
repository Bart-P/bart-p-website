---
import { siteConfig } from "../../config/site";
---

<nav class="bg-background text-text border-border w-full border-b">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
    <a href="/" class="text-lg font-semibold"> Bartek Para </a>

    <ul class="flex items-center gap-6">
      {
        siteConfig.nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="hover:text-secondary text-sm font-medium"
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <span class="font-bold">EN</span> | <span class="text-muted">DE</span>
      </li>
      <li>
        <a
          href="/"
          class="text-background bg-primary hover:bg-primary/80 hover:text-text/90 rounded px-3 py-2 text-lg font-semibold transition"
        >
          Book a call
        </a>
      </li>
    </ul>
  </div>
</nav>
