---
interface Props {
    content: {
        brand: string;
        tagline: string;
        links: readonly {
            label: string;
            href: string;
        }[];
    };
}

const { content: footer } = Astro.props as Props;
---

<footer class="border-border border-t">
    <div class="max-w-6xl p-6 flex items-center justify-between mx-auto">
        <div>
            <p class="font-bold">{footer.brand}</p>
            <p>{footer.tagline}</p>
        </div>
        <ul class="flex gap-6">
            {
                footer.links.map((item) => (
                    <li>
                        <a class="cursor-pointer" href={item.href}>
                            {item.label}
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
</footer>
