---
import { contactContent } from "../../i18n/contact";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { type Lang } from "../../types";
import SectionHeader from "../ui/SectionHeader.astro";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props as Props;
const content = contactContent[lang];
---

<SiteLayout
    title={content.meta.title}
    description={content.meta.description}
    lang={lang}
>
    <section>
        <div class="space-y-6">
            <div class="flex items-center justify-between gap-6">
                <div class="flex-1/2">
                    <SectionHeader
                        label={content.hero.title}
                        title={content.hero.heading}
                        intro={content.booking.description}
                    />
                </div>

                <aside class="border-border flex-1/2 rounded-lg border p-6">
                    <div class="mb-4">
                        <h2 class="text-primary font-semibold">
                            {content.directContact.title}
                        </h2>
                        <p class="text-muted-foreground mt-2 text-sm">
                            {content.directContact.description}
                        </p>
                    </div>

                    <div class="space-y-3">
                        <div>
                            <p class="text-sm font-semibold">
                                {content.directContact.email.label}
                            </p>
                            <a
                                href={content.directContact.email.href}
                                class="text-secondary underline"
                            >
                                {content.directContact.email.value}
                            </a>
                        </div>

                        <div>
                            <p class="text-sm font-semibold">
                                {content.directContact.phone.label}
                            </p>
                            <a
                                href={content.directContact.phone.href}
                                class="text-secondary underline"
                            >
                                {content.directContact.phone.value}
                            </a>
                        </div>
                    </div>
                </aside>
            </div>
            <section class="space-y-6">
                <h1 class="text-2xl font-bold">{content.legal.title}</h1>
                <ul>
                    <li>{content.legal.label}</li>
                    <li>{content.legal.name}</li>
                    <li>{content.legal.shortForm}</li>
                    <li>{content.legal.streetWithNumber}</li>
                    <li>{content.legal.cityCodeWithCity}</li>
                    <li>{content.legal.country}</li>
                </ul>
                <ul>
                    <li>{content.legal.contact}</li>
                    <li>
                        {content.legal.responsibleLabel}
                        {content.legal.name}
                    </li>
                    <li>
                        {content.legal.taxNr}
                    </li>
                </ul>
            </section>
        </div>
    </section>
</SiteLayout>
