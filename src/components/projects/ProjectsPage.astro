---
import { projectsContent } from "../../i18n/projects";
import SiteLayout from "../../layouts/SiteLayout.astro";
import Hero from "./Hero.astro";
import Projects from "./Projects.astro";
import { type Lang } from "../../types";
import Cta from "../home/Cta.astro";
import { commonContent } from "../../i18n/common";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props as Props;
const content = projectsContent[lang];
const common = commonContent[lang];
const contactHref = common.nav.primaryCta.href;
---

<SiteLayout
    title={content.meta.title}
    description={content.meta.description}
    lang={lang}
>
    <Hero content={content.hero} />
    <Projects projects={content.projects} />
    <Cta content={content.cta} primaryCtaHref={contactHref} />
</SiteLayout>
